generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  TRANSCRIPTION
  TRANSLATION
  EXPORT
  BURN
  SUMMARY
  CHAPTERS
}

enum ExportFormat {
  SRT
  VTT
  TXT
  JSON
  ASS
}

enum TranscriptionProvider {
  WHISPER
  DEEPGRAM
  ASSEMBLYAI
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  READY
  ERROR
}

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String?
  avatarUrl     String?
  plan          String    @default("free")
  storageUsed   BigInt    @default(0)
  storageLimit  BigInt    @default(5368709120)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  exports       Export[]

  @@index([clerkId])
  @@index([email])
}

model Project {
  id            String        @id @default(cuid())
  userId        String
  title         String
  description   String?
  status        ProjectStatus @default(DRAFT)
  language      String        @default("en")
  duration      Float?
  thumbnailUrl  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaFiles    MediaFile[]
  subtitleTracks SubtitleTrack[]
  translations  Translation[]
  jobs          Job[]
  exports       Export[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model MediaFile {
  id              String    @id @default(cuid())
  projectId       String
  userId          String
  originalName    String
  mimeType        String
  size            BigInt
  storageKey      String    @unique
  storageUrl      String?
  audioKey        String?
  audioUrl        String?
  waveformData    Json?
  thumbnailKey    String?
  thumbnailUrl    String?
  duration        Float?
  sampleRate      Int?
  channels        Int?
  bitrate         Int?
  width           Int?
  height          Int?
  fps             Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtitleTracks  SubtitleTrack[]

  @@index([projectId])
  @@index([userId])
  @@index([storageKey])
}

model SubtitleTrack {
  id              String                @id @default(cuid())
  projectId       String
  mediaFileId     String
  language        String
  label           String?
  provider        TranscriptionProvider?
  confidence      Float?
  isDefault       Boolean               @default(false)
  isAutoGenerated Boolean               @default(true)
  wordTimestamps  Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaFile       MediaFile             @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  segments        SubtitleSegment[]
  translations    Translation[]
  exports         Export[]

  @@index([projectId])
  @@index([mediaFileId])
  @@index([language])
}

model SubtitleSegment {
  id              String        @id @default(cuid())
  trackId         String
  index           Int
  startTime       Float
  endTime         Float
  text            String
  words           Json?
  speaker         String?
  confidence      Float?
  style           Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  track           SubtitleTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([trackId, index])
  @@index([startTime])
}

model Translation {
  id              String        @id @default(cuid())
  projectId       String
  trackId         String
  targetLanguage  String
  sourceLanguage  String
  segments        Json
  status          JobStatus     @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track           SubtitleTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([trackId])
  @@index([targetLanguage])
}

model Job {
  id              String      @id @default(cuid())
  projectId       String
  type            JobType
  status          JobStatus   @default(PENDING)
  progress        Int         @default(0)
  metadata        Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Export {
  id              String       @id @default(cuid())
  projectId       String
  userId          String
  trackId         String
  format          ExportFormat
  storageKey      String?
  downloadUrl     String?
  options         Json?
  status          JobStatus    @default(PENDING)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           SubtitleTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}
